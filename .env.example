# TikTok Scrapper local environment
# Copy this file to .env and replace placeholders as needed.

APP_NAME=TikTok Scrapper
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tiktok_scrapper
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tiktok_scrapper

MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_AUTH_CODE=
TIKTOK_OAUTH_STATE=
TIKTOK_REGION=BR
TIKTOK_TOKEN_CACHE_FILE=.cache/auth/tiktok_token.json
# Register this local redirect URI in TikTok Shop during local testing:
# http://localhost:8000/auth/tiktok/callback
# Configure the same `state` value in TikTok Shop and in the local callback:
# TIKTOK_OAUTH_STATE=replace-with-random-local-state

SEED_PROFILE=smoke
REPORT_TIMEZONE=America/Sao_Paulo
DEFAULT_AGENT_COUNT=3

# ── Ingestion Backend ─────────────────────────────────────────────────────
# "apify"    → 3-actor Apify pipeline (current, while awaiting API approval)
# "official" → TikTok Shop Partner API (set after approval is granted)
INGESTION_BACKEND=apify

# ── Apify Configuration ───────────────────────────────────────────────────
APIFY_TOKEN=apify_api_gpDAYyHBvlzawmbDfJL5SZSZMmedCc3MXqaES

# Actor IDs (override only if you want to swap to a different actor version)
APIFY_ACTOR_PRODUCTS=apidojo~tiktok-scraper
APIFY_ACTOR_SHOP=pro100chok~tiktok-shop-scraper-usage
APIFY_ACTOR_VIDEOS=clockworks~tiktok-scraper

# Ingestion limits
INGESTION_KEYWORDS=luminaria led,massageador portatil,kit skincare
INGESTION_MAX_PRODUCTS_PER_KEYWORD=100
INGESTION_MAX_VIDEOS_PER_KEYWORD=50
INGESTION_CACHE_DIR=.cache/ingestion
INGESTION_DAYS_LOOKBACK=30

# ── Google Trends (BR) ────────────────────────────────────────────────────
GOOGLE_TRENDS_GEO=BR
GOOGLE_TRENDS_LANG=pt-BR
